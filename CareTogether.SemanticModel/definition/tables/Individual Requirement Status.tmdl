	partition 'Individual Requirement Status' = m
		mode: import
		queryGroup: Fact
		source = ```
				let
				    Source = #"OData Live",
				    IndividualRequirements = Source{[Name="IndividualRequirementStatuses", Signature="table"]}[Data],
				
				    AddRLSKey =
				        Table.AddColumn(
				            IndividualRequirements,
				            "RLS Key",
				            each Text.Combine({[OrganizationId], [LocationId]}, "-")
				        ),
				
				    AddPersonUID =
				        Table.AddColumn(
				            AddRLSKey,
				            "Person UID",
				            each Text.Combine({[RLS Key], [PersonId]}, "-")
				        ),
				
				    Renamed =
				        Table.RenameColumns(
				            AddPersonUID,
				            {{"RequirementName", "Requirement"}, {"ExpireDate", "Expire Date"}}
				        ),
				
				    Selected =
				        Table.SelectColumns(
				            Renamed,
				            {"RLS Key", "Person UID", "PersonId", "Requirement", "Status", "Date", "Expire Date"}
				        ),
				
				
				    AddEffectiveDate =
				        Table.AddColumn(
				            Selected,
				            "Effective Date",
				            each if [Date] <> null then [Date] else [Expire Date],
				            type datetime
				        ),
				
				    Sorted =
				        Table.Sort(
				            AddEffectiveDate,
				            {
				                {"Person UID", Order.Ascending},
				                {"Requirement", Order.Ascending},
				                {"Effective Date", Order.Descending}
				            }
				        ),
				
				    Grouped =
				        Table.Group(
				            Sorted,
				            {"Person UID", "Requirement"},
				            {{"Data", each Table.AddIndexColumn(_, "Index", 0, 1, Int64.Type)}}
				        ),
				
				    Expanded =
				        Table.ExpandTableColumn(
				            Grouped,
				            "Data",
				            {"RLS Key", "PersonId", "Status", "Date", "Expire Date", "Effective Date", "Index"}
				        ),
				
				    AddFlag =
				        Table.AddColumn(
				            Expanded,
				            "Is Latest Status",
				            each [Index] = 0,
				            type logical
				        ),
				
				    FinalQuery = 
				        Table.SelectColumns(
				            AddFlag,
				            {"RLS Key", "Person UID", "Requirement", "Status", "Date", "Expire Date", "Is Latest Status"}
				        ),
				    #"Changed Type" = Table.TransformColumnTypes(FinalQuery,{{"Date", type datetime}, {"Expire Date", type datetime}})
				
				in
				    #"Changed Type"
				```

