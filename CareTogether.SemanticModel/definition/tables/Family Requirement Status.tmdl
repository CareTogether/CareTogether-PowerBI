table 'Family Requirement Status'
	lineageTag: 9b42f978-20bd-47f4-82ec-c84e4f70d5f5

	measure 'Family Requirement Status Icon' =
			SWITCH(
			    SELECTEDVALUE('Family Requirement Status'[Status]),
			    "Complete", "✅",
			    "Pending", "❌",
			    "Exempted", "⚪"
			)
		lineageTag: bbf86485-e8d1-41bf-8112-e72aef277b41

	measure '# of Families with Requirements' = DISTINCTCOUNT('Family Requirement Status'[Family Name])
		formatString: 0
		lineageTag: fc5aa783-35cb-4a9f-b0e7-1d1a527b6260

	measure 'Family Compliance Status' =
			
			VAR TotalReqs = COUNTROWS('Family Requirement Status')
			
			VAR ExpiredReqs = CALCULATE(
			    COUNTROWS('Family Requirement Status'),
			    'Family Requirement Status'[Status] IN { "Complete", "Exempted"},
			    'Family Requirement Status'[Expire Date] < TODAY(),
			    NOT ISBLANK('Family Requirement Status'[Expire Date]),
			    'Family Requirement Status'[Is Latest Status]
			)
			
			VAR PendingReqs = CALCULATE(
			    COUNTROWS('Family Requirement Status'),
			    'Family Requirement Status'[Status] = "Pending",
			    'Family Requirement Status'[Is Latest Status]
			)
			
			VAR ExpireSoonReqs = CALCULATE(
			    COUNTROWS('Family Requirement Status'),
			    'Family Requirement Status'[Expire Date] >= TODAY(),
			    'Family Requirement Status'[Expire Date] <= TODAY() + 30,
			    NOT ISBLANK('Family Requirement Status'[Expire Date]),
			    'Family Requirement Status'[Is Latest Status]
			)
			
			RETURN SWITCH(
			    TRUE(),
			    TotalReqs = 0, BLANK(),
			    ExpiredReqs > 0, "Expired",
			    PendingReqs > 0, "In Progress",
			    ExpireSoonReqs > 0, "Expiring Soon",
			    "Approved"
			)
		lineageTag: 4c21bf6e-cba0-49be-972b-eb3b749278d0

	measure '# of Families Approved' =
			COUNTROWS(
			    FILTER(
			        VALUES('Family Requirement Status'[Family Name]),
			        [Family Compliance Status] = "Approved"
			    )
			)
		formatString: 0
		lineageTag: b012d8e2-9fb6-40c5-aa9e-fb8004a668c5

	measure '# of Families In Progress' =
			COUNTROWS(
			    FILTER(
			        VALUES('Family Requirement Status'[Family Name]),
			        [Family Compliance Status] = "In Progress"
			    )
			)
		formatString: 0
		lineageTag: e596695d-a5e7-4b72-9277-14c02145bf16

	measure '# of Families Expiring Soon' =
			COUNTROWS(
			    FILTER(
			        VALUES('Family Requirement Status'[Family Name]),
			        [Family Compliance Status] = "Expiring Soon"
			    )
			)
		formatString: 0
		lineageTag: 4002bd4f-7879-481e-a582-e6f851ba1da6

	measure '# of Families Expired' =
			COUNTROWS(
			    FILTER(
			        VALUES('Family Requirement Status'[Family Name]),
			        [Family Compliance Status] = "Expired"
			    )
			)
		formatString: 0
		lineageTag: b72dcb1b-246f-4f4e-8ffc-9e9583a8503f

	measure '# of Families Overall Approval' = DIVIDE([# of Families Approved], [# of Families with Requirements])
		formatString: 0%;-0%;0%
		lineageTag: f14677ba-0721-45b8-838d-e0211eb8506d

	measure '# of Families Overall Approval Target' = [# of Families with Requirements] - [# of Families Approved]
		formatString: 0
		lineageTag: a6b81d7c-6d2d-4d42-8507-6481e215de1f

	measure '# of Requirements Completed (Family)' =
			CALCULATE(
			    DISTINCTCOUNT('Family Requirement Status'[Requirement]),
			    'Family Requirement Status'[Status] IN { "Complete", "Exempted" },
			    (
			        ISBLANK('Family Requirement Status'[Expire Date])
			        ||
			        'Family Requirement Status'[Expire Date] >= TODAY() + 30
			    ),
			    'Family Requirement Status'[Is Latest Status]
			)
		formatString: 0
		lineageTag: 5a0f1241-c970-44f4-8dcc-5360763992c0

	measure '# of Requirements Pending (Family)' =
			CALCULATE(
			    DISTINCTCOUNT('Family Requirement Status'[Requirement]),
			    'Family Requirement Status'[Status] = "Pending",
			    'Family Requirement Status'[Is Latest Status]
			)
		formatString: 0
		lineageTag: 3a1d6ba0-5fc1-416c-970c-a415ff633daf

	measure '# of Requirements Expired (Family)' =
			CALCULATE(
			    DISTINCTCOUNT('Family Requirement Status'[Requirement]),
			    'Family Requirement Status'[Status] IN { "Complete", "Exempted" },
			    'Family Requirement Status'[Expire Date] < TODAY(),
			    NOT ISBLANK('Family Requirement Status'[Expire Date]),
			    'Family Requirement Status'[Is Latest Status]
			)
		formatString: 0
		lineageTag: 47452cbd-1efd-4d7d-9ade-a9f051d0cbea

	measure '# of Requirements Expiring Soon (Family)' =
			CALCULATE(
			    DISTINCTCOUNT('Family Requirement Status'[Requirement]),
			    'Family Requirement Status'[Status] IN { "Complete", "Exempted"},
			    'Family Requirement Status'[Expire Date] >= TODAY(),
			    'Family Requirement Status'[Expire Date] <= TODAY() + 30,
			    NOT ISBLANK('Family Requirement Status'[Expire Date]),
			    'Family Requirement Status'[Is Latest Status]
			)
		formatString: 0
		lineageTag: 865919d2-80a5-4445-bb39-3f0eb4f47b6d

	measure 'Drill Down Visibility Flag (Family)' =
			
			VAR HasFamilyFilter =
			    ISFILTERED('Family Requirement Status'[Family Name])
			
			RETURN
			IF(
			    HasFamilyFilter,
			    1,
			    BLANK()
			)
		formatString: 0
		lineageTag: 9f2337e1-94c7-4525-8a39-0119db08e15d

