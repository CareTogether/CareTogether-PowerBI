	partition 'Family Requirement Status' = m
		mode: import
		queryGroup: Fact
		source = ```
				let
				    Source = #"OData Live",
				    FamilyRequirements = Source{[Name="FamilyRequirementStatuses", Signature="table"]}[Data],
				
				    AddRLSKey =
				        Table.AddColumn(
				            FamilyRequirements,
				            "RLS Key",
				            each Text.Combine({[OrganizationId], [LocationId]}, "-")
				        ),
				
				    AddFamilyUID =
				        Table.AddColumn(
				            AddRLSKey,
				            "Family UID",
				            each Text.Combine({[RLS Key], [FamilyId]}, "-")
				        ),
				
				    Renamed =
				        Table.RenameColumns(
				            AddFamilyUID,
				            {{"RequirementName", "Requirement"}, {"ExpireDate", "Expire Date"}}
				        ),
				
				    Selected =
				        Table.SelectColumns(
				            Renamed,
				            {"RLS Key", "Family UID", "FamilyId", "Requirement", "Status", "Date", "Expire Date"}
				        ),
				
				    AddEffectiveDate =
				        Table.AddColumn(
				            Selected,
				            "Effective Date",
				            each if [Date] <> null then [Date] else [Expire Date],
				            type datetime
				        ),
				
				    Sorted =
				        Table.Sort(
				            AddEffectiveDate,
				            {
				                {"Family UID", Order.Ascending},
				                {"Requirement", Order.Ascending},
				                {"Effective Date", Order.Descending}
				            }
				        ),
				
				    Grouped =
				        Table.Group(
				            Sorted,
				            {"Family UID", "Requirement"},
				            {{"Data", each Table.AddIndexColumn(_, "Index", 0, 1, Int64.Type)}}
				        ),
				
				    Expanded =
				        Table.ExpandTableColumn(
				            Grouped,
				            "Data",
				            {"RLS Key", "FamilyId", "Status", "Date", "Expire Date", "Effective Date", "Index"}
				        ),
				
				    AddFlag =
				        Table.AddColumn(
				            Expanded,
				            "Is Latest Status",
				            each [Index] = 0,
				            type logical
				        ),
				
				    FinalQuery = 
				        Table.SelectColumns(
				            AddFlag,
				            {"RLS Key", "Family UID", "Requirement", "Status", "Date", "Expire Date", "Is Latest Status"}
				        ),
				    #"Changed Type" = Table.TransformColumnTypes(FinalQuery,{{"Date", type datetime}, {"Expire Date", type datetime}})
				
				in
				    #"Changed Type"
				```

